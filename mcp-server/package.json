{
  "name": "@dialsmart/mcp-server",
  "version": "0.2.0",
  "description": "Fail-closed Model Context Protocol observer server exposing four tenant-scoped Dial Smart read tools.",
  "type": "module",
  "bin": {
    "dialsmart-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
