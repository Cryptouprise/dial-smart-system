    "telemarketing_calls_authorized": true,
    "not_condition_of_purchase": true,
    "effective_from": "<ISO-8601-timestamp>",
    "effective_to": null,
    "approver": "<compliance-or-counsel-reviewer>",
    "approved_at": "<ISO-8601-timestamp>"
  },
  "state_rule_source": {
    "policy_id": "<immutable-state-policy-id>",
    "approver": "<compliance-or-counsel-reviewer>",
    "approved_at": "<ISO-8601-timestamp>",
    "sha256": "<64-hex-sha256-of-state-policy-memo>",
    "source_urls": [
      "https://<authoritative-source>"
    ]
  },
  "per_lead_suppression_check": {
    "clear": true,
    "evidence_id": "<immutable-provider-or-registry-result-id>",
    "checked_at": "<ISO-8601-timestamp-at-or-before-dispatch>"
  },
  "required_suppression_check_keys": [
    "company_do_not_call_clear_required",
    "national_do_not_call_clear_required",
